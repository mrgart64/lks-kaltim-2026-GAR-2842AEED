APP_NAME="Kaltim Smart Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=kaltim_smart_platform
DB_USERNAME=root
DB_PASSWORD=

JWT_SECRET=
JWT_ALGO=HS256

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log

# AWS (opsional - untuk produksi)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=kaltim-uploads

# Amazon Lex Chatbot (opsional - kosongkan untuk fallback rule-based)
AWS_LEX_BOT_ID=
AWS_LEX_BOT_ALIAS_ID=

# File storage driver (public = local disk, s3 = AWS S3)
FILESYSTEM_DISK=public
